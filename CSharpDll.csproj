<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net462</TargetFramework>
    <OutputType>Library</OutputType>
    <RootNamespace>MusicBeePlugin</RootNamespace>
    <AssemblyName>mb_Browser2</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
    <UseWindowsForms>true</UseWindowsForms>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3908-prerelease" />
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="MusicBeeInterface.cs" />
    <Compile Include="Browser2.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Resources\iconmonstr-arrow-left-alt-filled-16.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-arrow-right-alt-filled-16.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-home-7-24.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-menu-square-lined-24.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-networking-6-16.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-networking-7-16.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-pin-2-24.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-pin-8-24.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-star-3-24.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-star-5-24.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-synchronization-3-24.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\iconmonstr-x-mark-9-24.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  <Target Name="CopyToMusicBee" AfterTargets="PostBuildEvent">
    <ItemGroup>
      <FilesToCopy Include="$(TargetDir)*.dll" />
      <FilesToCopy Include="$(TargetDir)*.pdb" />
      <FilesToCopy Include="$(TargetDir)*.config" />
      <FilesToCopy Include="$(TargetDir)*.xml" />
      <FilesToCopy Include="$(TargetDir)Resources\*.png" />
      <ResourceFiles Include="$(ProjectDir)Resources\*.png" />
    </ItemGroup>
    <Copy SourceFiles="@(FilesToCopy)" DestinationFolder="A:\Media\MusicBee\Plugins" SkipUnchangedFiles="true" ContinueOnError="WarnAndContinue" />
    <MakeDir Directories="A:\Media\MusicBee\Plugins\Resources" Condition="!Exists('A:\Media\MusicBee\Plugins\Resources')" />
    <Copy SourceFiles="@(ResourceFiles)" DestinationFolder="A:\Media\MusicBee\Plugins\Resources" SkipUnchangedFiles="true" ContinueOnError="WarnAndContinue" />
  </Target>
</Project>
